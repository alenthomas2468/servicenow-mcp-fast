# =============================================================================
# MCP ENDPOINT AUTH (remote HTTP deployments only - who may talk to this server)
# See docs/AUTHENTICATION.md. Leave all unset for local stdio use.
# =============================================================================
# Static bearer token for header-capable clients - generate: openssl rand -hex 32
# MCP_AUTH_TOKEN=

# Per-user ServiceNow OAuth for claude.ai / Claude Desktop custom connectors.
# Values come from an "OAuth API endpoint for external clients" record in the
# instance's Application Registry (redirect URL: <MCP_PUBLIC_URL>/auth/callback)
# SERVICENOW_OAUTH_CLIENT_ID=
# SERVICENOW_OAUTH_CLIENT_SECRET=
# MCP_PUBLIC_URL=https://your-domain.example.com

# ServiceNow Instance Configuration
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_TIMEOUT=30
SERVICENOW_DEBUG=false

# Authentication
# Type: basic, oauth, or api_key
SERVICENOW_AUTH_TYPE=basic

# Basic Auth
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_password

# OAuth
SERVICENOW_CLIENT_ID=your_client_id
SERVICENOW_CLIENT_SECRET=your_client_secret
SERVICENOW_TOKEN_URL=https://your-instance.service-now.com/oauth_token.do

# API Key
SERVICENOW_API_KEY=your_api_key
SERVICENOW_API_KEY_HEADER=X-ServiceNow-API-Key

# Script Execution
SCRIPT_EXECUTION_API_RESOURCE_PATH=/api/now/table/sys_script_include

# SSL Configuration
# For private network instances with custom SSL certificates (e.g., corporate network)
# SERVICENOW_SSL_CERT_PATH=C:\path\to\your\certificate.crt

# Disable SSL verification (NOT RECOMMENDED - use only for testing)
# WARNING: This makes your connection insecure! Only use in development/testing.
# Set to true if you're behind a corporate proxy with SSL inspection and don't have the CA certificate
# SERVICENOW_DISABLE_SSL_VERIFY=false

# SSL Configuration
# -----------------------------------------------------------------------------
# Option 1: For corporate networks with SSL inspection - use custom certificate
# Uncomment and set path to your corporate root CA certificate
# SERVICENOW_SSL_CERT_PATH=C:\Program Files\Repos\servicenow-mcp-fast\singtel-chain.crt

# Option 2: Disable SSL verification (NOT RECOMMENDED - only for testing)
# WARNING: This makes your connection insecure! Only use in development/testing.
# Set to true if behind corporate proxy without access to CA certificate
SERVICENOW_DISABLE_SSL_VERIFY=true

# -----------------------------------------------------------------------------
# QUICK SETUP GUIDE:
# -----------------------------------------------------------------------------
# 
# For public ServiceNow (dev309229.service-now.com) behind corporate proxy:
#   - Set SERVICENOW_DISABLE_SSL_VERIFY=true (temporary, for testing only)
#   - OR get corporate root CA cert and set SERVICENOW_SSL_CERT_PATH
#
# For private Singtel instance (tinadev.sg.singtelgroup.net):
#   - Change SERVICENOW_INSTANCE_URL to https://tinadev.sg.singtelgroup.net
#   - Set SERVICENOW_SSL_CERT_PATH=C:\Program Files\Repos\servicenow-mcp-fast\singtel-chain.crt
#   - Set SERVICENOW_DISABLE_SSL_VERIFY=false (or comment it out)
